# MEDIATA Node Configuration
# Copy to 'node-secrets.env' and update values

PORT=8080
NAME=MyNodeName
DESC=My MEDIATA node description
COLOR=#008000
NODE_IP=https://mynode.mediata.dev

# JWT Configuration (Required - use 32+ character string)
JWT_SECRET=your-secret-key-here-at-least-32-characters-long
JWT_EXPIRATION=86400
