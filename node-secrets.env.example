# MEDIATA Node Environment Configuration
# Copy this file to 'node-secrets.env' and configure with your actual values
# IMPORTANT: Never commit node-secrets.env to version control

# Server Configuration
PORT=8080

# Node Information
NAME=MyNodeName
DESC=My MEDIATA node description
COLOR=#008000

# Node URL (HTTPS recommended for production)
NODE_IP=https://mynode.mediata.dev

# JWT Configuration (REQUIRED - Must be 32+ characters for security)
JWT_SECRET=your-secret-key-here-at-least-32-characters-long-please-change-this

# JWT Token Expiration (in seconds)
JWT_EXPIRATION=86400

# Optional: Orchestrator URL
# ORCHESTRATOR_URL=https://orchestrator.mediata.dev

# Optional: Additional Java Options
# JAVA_OPTS=-Xmx2g -Xms512m
